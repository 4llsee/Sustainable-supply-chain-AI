      "source": [
        "# استيراد مكتبات تحليل البيانات والرسم البياني\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# تحميل وقراءة البيانات\n",
        "df = pd.read_csv(\"/content/MER_T12_06_cleaned.csv\")\n",
        "\n",
        "# لتسهيل عمليات التحليل الزمني ومعالجة البيانات \"datetime\" الى نوع \"Date\"تحويل عمود\n",
        "df['Date'] = pd.to_datetime(df['Date'])"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
