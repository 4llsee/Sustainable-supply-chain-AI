      "source": [
        "# مما يسمح بتحديد الانماط مثل التغيرات الموسمية او السنوية للأنبعاثات co2 هذا الرسم يوضح العلاقة بين الوقت وانبعاثات\n",
        "# الذي يضيف خلفية بيضاء لتسهيل قراءة المخطط Whitegrid وتحديد نمط الرسمة Seaborn تحديد إعدادات الرسم البياني بإستخدام مكتبة\n",
        "sns.set_theme(style=\"whitegrid\")\n",
        "\n",
        "# تعيين حجم الشكل البياني\n",
        "plt.figure(figsize=(12, 6))\n",
        "\n",
        "# عبر الزمن Co2 إنشاء مخطط خطي لعرض إنبعاثات\n",
        "# Co2 مع تحديد المحور الافقي ليكون التاريخ والمحور الرأسي ليمثل قيم إنبعاثات\n",
        "sns.lineplot(x=df['Date'], y=df['Value'])\n",
        "\n",
        "# تعيين عنوان للرسم البياني\n",
        "plt.title(\"CO₂ Emissions Over Time\")\n",
        "\n",
        "# تسمية المحاور\n",
        "plt.xlabel(\"Year\")\n",
        "plt.ylabel(\"CO₂ Emissions (Million Metric Tons)\")\n",
        "\n",
        "# تدوير تسميات المحور الافقي لتسهيل قراءته\n",
        "plt.xticks(rotation=45)\n",
        "\n",
        "# عرض الرسم البياني\n",
        "plt.show()"
      ]
    },
