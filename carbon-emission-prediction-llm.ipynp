      "source": [
        "# تعريف الأعمدة التي تحتوي على بيانات النفقات\n",
        "expense_columns = ['Housing_Cost_Percentage', 'Healthcare_Cost_Percentage', 'Education_Cost_Percentage', 'Transportation_Cost_Percentage']\n",
        "\n",
        "# تعيين حجم الرسم البياني\n",
        "plt.figure(figsize=(12, 6))\n",
        "\n",
        "# لعرض توزيع بيانات الفئات المختلفة (تكاليف الإسكان، الرعاية الصحية، التعليم، والنقل) Boxplot مخطط\n",
        "# Outliers يساعد المخطط في تحليل التوزيع والنطاق الطبيعي لكل فئة، مع عرض النقاط الشاذة\n",
        "# المحور الأفقي يمثل فئات التكاليف المختلفة (الإسكان، الرعاية الصحية، التعليم، النقل)\n",
        "# بينما المحور العمودي يمثل النسبة المئوية من الدخل التي يتم إنفاقها على كل فئة\n",
        "#:يمكن قراءة المخطط على النحو التالي\n",
        "# الخط في منتصف كل صندوق يمثل الوسيط لنسبة الدخل المنفقة على كل فئة\n",
        "# الجزء العلوي من الصندوق يمثل الربع الثالث والجزء السفلي يمثل الربع الأول\n",
        "# النقاط الشاذة تظهر خارج الحدود القصوى والحدود الادنى للصندوق وتُعتبر قيمًا غير طبيعية في البيانات\n",
        "# هذا المخطط يساعد على مقارنة توزيع النفقات بين الفئات المختلفة وفهم تباينها\n",
        "sns.boxplot(data=df[expense_columns])\n",
        "\n",
        "# إضافة عنوان للرسم البياني\n",
        "plt.title(\"Expense Category Distribution\")\n",
        "# تسمية المحور العمودي (النسبة المئوية من الدخل)\n",
        "plt.ylabel(\"Percentage of Income\")\n",
        "\n",
        "# تدوير تسميات المحاور\n",
        "# يستخدم هذا السطر لتدوير النصوص على المحور الأفقي بزاوية 45 درجة\n",
        "# هذا مفيد عندما تكون تسميات الفئات طويلة او مكتظة لتسهيل قراءتها في الرسم\n",
        "plt.xticks(rotation=45)\n",
        "\n",
        "#عرض الرسم البياني\n",
        "plt.show()"
      ]
    },
