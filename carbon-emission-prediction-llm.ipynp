        "# تحديد حجم الرسم البياني\n",
        "plt.figure(figsize=(12, 6))\n",
        "\n",
        "# حسب المنطقة الجغرافية Co2 لعرض انبعاثات  boxplot رسم مخطط\n",
        "sns.boxplot(data=df, x=\"Region\", y=\"CO2 Emissions\")\n",
        "\n",
        "# تدوير أسماء المناطق على المحورالافقي بزاوية 45 لتسهيل عملية القراءة\n",
        "plt.xticks(rotation=45)\n",
        "\n",
        "# إضافة عنوان للرسم البياني\n",
        "plt.title(\"CO₂ Emissions by Region\")\n",
        "\n",
        "#  تسمية المحور الرأسي\n",
        "plt.ylabel(\"CO₂ Emissions\")\n",
        "\n",
        "# عرض الرسم البياني\n",
        "plt.show()"
      ]
    },
