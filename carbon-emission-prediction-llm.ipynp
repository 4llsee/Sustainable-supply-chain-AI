        "# طباعة معلومات عامة حول البيانات مثل نوع البيانات وعدد القيم لكل عمود\n",
        "print(df.info())\n",
        "\n",
        "# عرض ملخص إحصائي للأعمدة الرقمية مثل المتوسط، والانحراف المعياري، والقيم القصوى\n",
        "print(df.describe())"
      ]
