    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "QtSpLVfmagC4"
      },
      "outputs": [],
      "source": [
        "# لإعادة تشكيل البيانات meltاستخدمنا الدالة\n",
        "# Year قمنا بتحويل أعمدة السنوات إلى صف واحد تحت عمود جديد اسمه\n",
        "# يحتوي على القيم المقابلة لكل سنة CO2 Emissionsانشأنا عمود اخر اسمه\n",
        "# كما هي بدون تغيير Counrty name, Country code, Region, Indicator ابقينا الاعمدة الاخرى\n",
        "# الهدف تسهيل التعامل مع البيانات لاحقا، حيث يصبح لدينا كل سنة في صف مستقل بدلا من أعمدة منفصلة\n",
        "df = df.melt(id_vars=[\"Country Name\", \"country_code\", \"Region\", \"Indicator Name\"],\n",
        "             var_name=\"Year\", value_name=\"CO2 Emissions\")\n",
        "\n",
        "# pd.to_numeric إلى صيغة رقمية بإستخدام  Year قمنا بتحويل القيم الموجودة في عمود\n",
        "# هذا يضمن ان السنوات يتم التعامل معها كأرقام وليست نصوص مما يسهل تحليل الرسوم البيانية\n",
        "# بدلا من ظهور خطأ Not a Number = NaN لتحويل أي قيمة غير قابلة لتتحويل إلى (errors=coerce)اضفنا\n",
        "df[\"Year\"] = pd.to_numeric(df[\"Year\"], errors=\"coerce\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 487
        },
        "id": "2Qz4Y6KyazDx",
        "outputId": "70149c55-d444-486d-cb3f-0e6e8a11a795"
      },
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 1000x500 with 1 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        }
      ],
      "source": [
        "# لجعل المخطط أوضح وأسهل للقراءة Whitegrid قمنا بضبط نمط الرسم بإستخدام\n",
        "sns.set_theme(style=\"whitegrid\")\n",
        "\n",
        "# قمنا بتعيين حجم الرسم البياني\n",
        "plt.figure(figsize=(10, 5))\n",
        "\n",
        "#  لتقسيم البيانات ل30 فئة ,bins=30 لأنبعاثات ثاني أكسيد الكربون بإستخدام Histogram إنشاء مخطط\n",
        "# لحساب كثافة الاحتمال في نقاط معينة في محور الدخل KDE لتوفير تمثيل مرن للتوزيع الاحتمالي للبيانات، يتم استخدام KDE إضافة\n",
        "sns.histplot(df[\"CO2 Emissions\"], bins=30, kde=True)\n",
        "\n",
        "# إضافة عنوان رئيسي للمخطط\n",
        "plt.title(\"Distribution of CO₂ Emissions\")\n",
        "\n",
        "# تسمية المحاور\n",
        "plt.xlabel(\"CO₂ Emissions (Metric Tons per Capita)\")\n",
        "plt.ylabel(\"Frequency\")\n",
        "\n",
        "# عرض الرسم البياني\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 487
        },
        "id": "xO4t64rJa2vW",
        "outputId": "a8c8c855-3e35-4257-a7de-3a60f8addd01"
      },
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 1200x600 with 1 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        }
      ],
      "source": [
        "# حيث يتم أولا حساب متوسط الانبعاثات لكل دولة Co2 نقوم هنا بتحليل بيانات انبعاثات\n",
        "# بعد ذلك يتم اختيار الدول الخمس ألاعلى حيث متوسط الانبعاثات\n",
        "top_countries = df.groupby(\"Country Name\")[\"CO2 Emissions\"].mean().nlargest(5).index\n",
        "# يتم إنشاء مجموعة بيانات فرعية تحتوي فقط على هذه الدول الخمس\n",
        "df_top = df[df[\"Country Name\"].isin(top_countries)]\n",
        "\n",
        "# تعيين حجم الرسم البياني\n",
        "plt.figure(figsize=(12, 6))\n",
        "\n",
        "# لهذه الدول بمرور السنوات Co2 رسم مخطط خطي يوضح تطور انبعاثات\n",
        "# مع تمييز كل دولة بأستخدام ألوان مختلفة وعرض النقاط على الخطوط البيانية\n",
        "sns.lineplot(data=df_top, x=\"Year\", y=\"CO2 Emissions\", hue=\"Country Name\", marker=\"o\")\n",
        "\n",
        "# إضافة عنوان رئيسي للرسم البياني\n",
        "plt.title(\"CO₂ Emissions Over Time (Top 5 Countries)\")\n",
        "\n",
        "# تسمية المحاور\n",
        "plt.xlabel(\"Year\")\n",
        "plt.ylabel(\"CO₂ Emissions\")\n",
        "\n",
        "# لها وستبين للقارئ أن الألوان او الخطوط تمثل دول مختلفة (Country) دالة تستخدم لإضافة وسيلة إيضاح للرسم البياني، اضفنا عنوان\n",
        "plt.legend(title=\"Country\")\n",
        "\n",
        "# عرض الرسم البياني\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "code",
